<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="/socket.io/socket.io.js"></script>
</head>
<body>
    <div class="game-container">
        <div class="game-header">
            <h1>Словарная игра</h1>
            <a href="/" class="exit-btn">Выйти</a>
        </div>

        <div class="game-main">
            <div class="game-info-panel">
                <div class="players-list">
                    <h3>Игроки</h3>
                    <div id="playersList">
                        <div class="loading">Загрузка...</div>
                    </div>
                </div>

                <div class="game-status">
                    <div class="status-card">
                        <div class="status-label">Статус игры</div>
                        <div id="gameStatus" class="status-value">Ожидание игроков</div>
                    </div>
                    <div class="status-card">
                        <div class="status-label">Текущий ход</div>
                        <div id="currentTurn" class="status-value">—</div>
                    </div>
                    <div class="status-card">
                        <div class="status-label">Буква</div>
                        <div id="currentLetter" class="status-value big-letter">—</div>
                    </div>
                    <div class="status-card">
                        <div class="status-label">Время</div>
                        <div id="timeLeft" class="status-value timer">—</div>
                    </div>
                </div>

                <div class="word-input-area">
                    <input type="text" id="wordInput" placeholder="Введите слово на заданную букву..." maxlength="30">
                    <button id="submitWordBtn" class="btn-word">Отправить слово</button>
                </div>
            </div>

            <div class="chat-panel">
                <div class="chat-header">
                    <h3>Игровой чат</h3>
                    <button id="readyBtn" class="btn-ready">Готов к игре</button>
                </div>
                <div class="chat-messages" id="chatMessages">
                    <div class="system-message">Подключение к игре...</div>
                </div>
                <div class="chat-input-area">
                    <input type="text" id="chatInput" placeholder="Введите сообщение..." maxlength="100">
                    <button id="sendChatBtn" class="btn-chat">Отправить</button>
                </div>
            </div>
        </div>
    </div>

    <script src="/js/game.js"></script>
</body>
</html>